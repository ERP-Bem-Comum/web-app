# .env.example — modelo de ambiente do BFF (server-only). Copie para `.env` e ajuste.
#   cp .env.example .env
#
# Validado por Zod fail-fast em src/external/config/env.config.ts: se faltar/for inválido,
# a server function LANÇA (e a tela de login mostra "Algo deu errado"). NUNCA use prefixo
# VITE_ aqui — estas variáveis não podem ir ao bundle do browser (token/URL ficam server-side).

# Base URL do core-api (backend), usada pelo BFF para autenticar/orquestrar. O browser nunca vê.
# - Local (pnpm dev): aponte para o core-api rodando na sua máquina.
# - Stack completo (docker compose): o compose já injeta CORE_API_URL=http://core-api:3000/api/v2
#   (rede interna); neste caso você NÃO precisa de .env.
CORE_API_URL=http://localhost:3001/api/v2
