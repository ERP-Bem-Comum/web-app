{
  "name": "web-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "imports": {
    "#app/*": "./src/app/*",
    "#shared/*": "./src/shared/*",
    "#external/*": "./src/external/*",
    "#modules/*": "./src/modules/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "prepare": "husky",
    "claude:check": "node .claude/check.mjs",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.ts\"",
    "test:watch": "node --experimental-strip-types --test --watch \"tests/**/*.test.ts\"",
    "test:dom": "vitest run",
    "test:all": "pnpm test && pnpm test:dom",
    "test:e2e": "playwright test",
    "test:visual": "playwright test e2e/visual/",
    "test:visual:update": "playwright test e2e/visual/ --update-snapshots",
    "test:visual:ui": "playwright test e2e/visual/ --ui"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.9",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.16",
    "@vanilla-extract/css": "^1.20.1",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/eslint-plugin-start": "^0.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-zod": "^4.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "nitro": "3.0.260522-beta",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
